{
  "name": "twinroute",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "npm run build -w @inspector/contract && npm run build -w @inspector/ui && npm run build -w @inspector/twinroute",
    "dev": "npm run dev -w @inspector/twinroute",
    "start": "npm run start -w @inspector/twinroute",
    "test": "npm run build && vitest run",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
